# .env.example — Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control. It is listed in .gitignore.
# This .env.example file IS committed — it documents required variables without
# containing real secrets.

# ─── LRU Cache ────────────────────────────────────────────────────────────────

# Maximum number of entries the cache will hold before evicting the LRU item.
LRUCACHE_CAPACITY=100

# ─── ASP.NET Core ─────────────────────────────────────────────────────────────

# Runtime environment. Production disables the HTTPS redirect inside Docker.
# Options: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Production
